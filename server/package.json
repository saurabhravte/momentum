{
  "name": "@momentum/server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "echo ok",
    "test": "vitest run",
    "db:push": "drizzle-kit push",
    "db:migrate:corsair": "tsx scripts/migrate-corsair.ts",
    "setup:corsair": "tsx scripts/setup-corsair-oauth.ts",
    "perf": "node scripts/perf-check.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.177",
    "@anthropic-ai/sdk": "^0.104.1",
    "@corsair-dev/github": "^0.1.10",
    "@corsair-dev/gmail": "^0.1.4",
    "@corsair-dev/googlecalendar": "^0.1.4",
    "@corsair-dev/mcp": "^0.1.22",
    "@corsair-dev/slack": "^0.1.4",
    "@momentum/shared": "workspace:*",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "corsair": "^0.1.76",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "nanoid": "^5.1.11",
    "pg": "^8.21.0",
    "pg-boss": "^12.19.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
