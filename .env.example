# ============================================================================
# Momentum environment. Copy to `server/.env` (the server reads this) and fill
# in. Values marked REQUIRED must be set or the server refuses to boot (see
# server/src/common/config/env.ts).
# ============================================================================

# --- Core (REQUIRED) -------------------------------------------------------
NODE_ENV=development
API_PORT=4000
WEB_ORIGIN=http://localhost:3000
API_ORIGIN=http://localhost:4000

# Postgres. Local docker-compose service is named "db".
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/momentum

# Key-encryption key for Corsair's encrypted OAuth-token storage (REQUIRED).
#   generate with:  openssl rand -base64 32
CORSAIR_KEK=

# Signs/identifies the session cookie (REQUIRED, min 32 chars).
#   generate with:  openssl rand -base64 32
SESSION_SECRET=

# --- Google: login + Gmail + Calendar --------------------------------------
# One OAuth client in Google Cloud Console covers all three. Add BOTH redirect
# URIs below to "Authorized redirect URIs", and enable the Gmail API and the
# Google Calendar API for the project.
#   1) login identity:     http://localhost:4000/api/auth/google/callback
#   2) Corsair connectors: http://localhost:4000/api/connections/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# --- AI (Anthropic) --------------------------------------------------------
# Used by the classifier, drafting, and the agent. Without it, AI features
# return errors but the rest of the app runs.
ANTHROPIC_API_KEY=
AI_CLASSIFIER_MODEL=claude-haiku-4-5-20251001
AI_AGENT_MODEL=claude-sonnet-4-6
# Optional fallback provider:
OPENROUTER_API_KEY=
AI_FREE_MODEL=meta-llama/llama-3.1-8b-instruct:free

# --- Optional integrations (Slack / GitHub use API keys, not OAuth) --------
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Optional: inbound provider webhooks (Gmail push, etc.) ----------------
WEBHOOK_PUBLIC_URL=
WEBHOOK_SIGNING_SECRET=

# --- Client ----------------------------------------------------------------
# The Next.js app proxies /api/* to this origin (see client/next.config.ts).
NEXT_PUBLIC_API_URL=http://localhost:4000
